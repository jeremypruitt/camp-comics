# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/

# macOS
.DS_Store

# Camp Comics — legacy Python runtime artifacts
# Camper data: keep tokens.json (cheap, hand-curated) but ignore the heavy
# intermediate images AND the source photos themselves (face data stays out
# of git by default; commit a synthetic test corpus only if needed).
# Patterns are doubly-anchored (`**/`) so they catch files under _legacy/
# as well as any future repro corpus at the root.
**/intake/*/photo.jpg
**/intake/*/qa_test.png
**/outputs/*/_pending_*.png
**/outputs/*/_diag_*.png
**/outputs/*/_attempts.json
**/outputs/*/_skipped_*
**/outputs/*/manifest.json

# Final renders are big (~17 MB each) — don't put binaries in git history.
**/outputs/*/panel_*.png
**/outputs/*/cover.png
**/outputs/*/comic.pdf

# IDE
.vscode/
.idea/
*.swp

# Xcode — per-user state and build output, never share
**/xcuserdata/
**/*.xcuserstate
DerivedData/
build/
build-device/

# SwiftPM build artifacts (from `swift build` / `swift test`)
.build/
.swiftpm/
